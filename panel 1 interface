<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Wolf - Panel Officiel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        :root {
            --bg: #0d1117;
            --panel: #001f3f;
            --line: #003366;
            --accent: #a0c4ff;
            --white: #ffffff;
            --radius: 18px;
        }

        body {
            background: var(--bg);
            color: var(--white) !important;
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0;
            overflow: hidden; /* Empêche le double scroll */
        }

        /* SIDEBAR (TON MENU) */
        .sidebar {
            background: var(--panel);
            height: 100vh;
            width: 290px;
            position: fixed;
            border-right: 2px solid var(--line);
            padding-top: 20px;
            z-index: 1000;
        }

        .sidebar-logo {
            display: flex;
            justify-content: center;
            padding-bottom: 25px;
        }

        .sidebar-logo img {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 20px;
            border: 2px solid var(--accent);
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }

        .nav-link {
            color: var(--accent) !important;
            font-size: 1.05rem;
            padding: 14px 24px !important;
            margin: 8px 16px;
            border-radius: 14px;
            cursor: pointer;
            transition: 0.2s;
            text-decoration: none;
            display: block;
        }

        .nav-link:hover, .nav-link.active {
            background: var(--line);
            color: white !important;
            box-shadow: 0 0 15px rgba(0,63,102,0.4);
        }

        /* ZONE DE CONTENU (LÀ OÙ LES SCRIPTS APPARAÎTRONT) */
        main {
            margin-left: 290px;
            padding: 34px;
            height: 100vh;
            overflow-y: auto;
        }

        .main-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 30px;
        }

        .pill-status {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 999px;
            background: rgba(15, 28, 46, 0.85);
            border: 1px solid rgba(160, 196, 255, 0.22);
            font-weight: 700;
        }
    </style>
</head>
<body>

<nav class="sidebar">
    <div class="sidebar-logo">
        <img src="https://api.lyg.fr/img/logo.png" alt="Wolf Logo">
    </div>

    <ul class="nav flex-column">
        <li><a class="nav-link active" id="btn-membres"><i class="fas fa-users me-3"></i>Membres</a></li>
        <li><a class="nav-link" id="btn-points"><i class="fas fa-trophy me-3"></i>Points Famille</a></li>
        <li><a class="nav-link" id="btn-classement"><i class="fas fa-ranking-star me-3"></i>Classement</a></li>
        <li><a class="nav-link" id="btn-admin" style="color:#ff7c7c !important;"><i class="fas fa-lock me-3"></i>Mode Admin</a></li>
    </ul>
</nav>

<main>
    <div class="main-header">
        <div class="pill-status">
            <i class="fa-solid fa-shield-halved text-info"></i>
            <span>The Wolf · Système Officiel</span>
        </div>
    </div>

    <div id="dynamic-content">
        <h3 class="text-center mt-5 opacity-50">Sélectionnez une catégorie dans le menu</h3>
    </div>
</main>

</body>
</html>
