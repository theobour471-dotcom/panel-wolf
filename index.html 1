<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>The Wolf - Panel Officiel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <style>
        :root { --bg: #0d1117; --panel: #001f3f; --line: #003366; --accent: #a0c4ff; --white: #ffffff; }
        body { background: var(--bg); color: var(--white) !important; font-family: 'Segoe UI', sans-serif; margin: 0; overflow: hidden; }
        .sidebar { background: var(--panel); height: 100vh; width: 290px; position: fixed; border-right: 2px solid var(--line); padding-top: 20px; }
        .sidebar-logo { display: flex; justify-content: center; padding-bottom: 25px; }
        .sidebar-logo img { width: 110px; border-radius: 20px; border: 2px solid var(--accent); }
        .nav-link { color: var(--accent) !important; padding: 14px 24px; margin: 8px 16px; border-radius: 14px; cursor: pointer; display: block; text-decoration: none; transition: 0.1s; }
        .nav-link:hover, .nav-link.active { background: var(--line); color: white !important; }
        main { margin-left: 290px; padding: 34px; height: 100vh; overflow-y: auto; }
        .member-card { background: rgba(15, 28, 46, 0.7); border: 1px solid var(--line); border-radius: 12px; padding: 15px; margin-bottom: 10px; }
        .n-info { color: var(--accent); font-weight: bold; }
    </style>
</head>
<body>

<nav class="sidebar">
    <div class="sidebar-logo"><img src="https://api.lyg.fr/img/logo.png" alt="Wolf Logo"></div>
    <ul class="nav flex-column">
        <li><a class="nav-link active" onclick="loadMembres(this)"><i class="fas fa-users me-3"></i>Membres</a></li>
        <li><a class="nav-link" href="points.html"><i class="fas fa-trophy me-3"></i>Points & Banque</a></li>
        <li><a class="nav-link" href="classement.html"><i class="fas fa-ranking-star me-3"></i>Classement</a></li>
    </ul>
</nav>

<main>
    <div id="dynamic-content">
        </div>
</main>

<script>
const API_BASE = "https://api.lyg.fr/api";
const familyName = 'Wolf';

// Système de cache pour les noms (Correction "Non défini")
const CACHE = JSON.parse(localStorage.getItem('wolf_names_v15') || '{}');

async function getPseudo(id) {
    if (CACHE[id]) return CACHE[id];
    try {
        const r = await fetch(`${API_BASE}/global/player/${id}`).then(d => d.json());
        const n = r.data?.last_name || r.last_name || id;
        CACHE[id] = n;
        localStorage.setItem('wolf_names_v15', JSON.stringify(CACHE));
        // Met à jour tous les endroits où ce SteamID apparaît
        document.querySelectorAll(`.n-${id}`).forEach(el => el.innerText = n);
    } catch(e) {}
}

async function loadMembres(el) {
    if(el) {
        document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
        el.classList.add('active');
    }
    
    const area = document.getElementById('dynamic-content');
    area.innerHTML = `<div class="text-center p-5"><div class="spinner-border text-info"></div><br>Chargement de la meute...</div>`;

    const r = await fetch(`${API_BASE}/darkrp/familles/${familyName}/members`).then(d => d.json());
    let h = `<h2>Membres de la Famille</h2><div class="row">`;
    
    (r.data || []).forEach(m => {
        getPseudo(m.steamid); // On lance la recherche du nom en arrière-plan
        h += `
        <div class="col-md-6">
            <div class="member-card">
                <div class="n-info n-${m.steamid}">${CACHE[m.steamid] || m.steamid}</div>
                <small class="text-white-50">${m.steamid}</small>
            </div>
        </div>`;
    });
    
    area.innerHTML = h + `</div>`;
}

// Lancer les membres au démarrage
loadMembres();
</script>
</body>
</html>
